# Auto detect text files and perform LF normalization
* text=auto

# TypeScript files
*.ts text eol=lf
*.tsx text eol=lf

# JavaScript files
*.js text eol=lf
*.jsx text eol=lf

# JSON files
*.json text eol=lf

# Markdown files
*.md text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
package.json text eol=lf
tsconfig.json text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files
*.vsix binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
